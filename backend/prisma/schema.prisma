generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // Connection pooling is configured via the DATABASE_URL connection string
  // Example with PgBouncer: postgresql://user:password@localhost:5432/amana?pgbouncer=true
  // For production, ensure the connection pool size is appropriate for your workload:
  // - connection_limit: typically 20-100 connections
  // - pool_mode: use 'transaction' or 'session' mode based on your needs
}

enum TradeStatus {
  PENDING_SIGNATURE
  CREATED
  FUNDED
  DELIVERED
  COMPLETED
  DISPUTED
  CANCELLED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  CLOSED
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ChainEventSyncStatus {
  PENDING
  RETRYING
  PROCESSED
  DEAD_LETTER
}

/// User model representing a participant in the Amana platform
/// - walletAddress: Stellar wallet address (stored as lowercase for consistency)
/// - displayName: User's display name
/// - createdAt: Timestamp of account creation
model User {
  id              Int              @id @default(autoincrement())
  /// Unique wallet address (always stored as lowercase)
  walletAddress   String           @unique @db.VarChar(255)
  displayName     String           @db.VarChar(255)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // Relations
  tradesBought    Trade[]          @relation("buyer")
  tradesSold      Trade[]          @relation("seller")
  initiatedDisputes Dispute[]      @relation("initiator")
  vaults          Vault[]
  goals           Goal[]
  tradeTemplates  TradeTemplate[]
  watchlist       UserWatchlist[]
  refreshTokens   RefreshToken[]
  wallets         UserWallet[]
  webhooks        Webhook[]
  webhookSubscriptions WebhookSubscription[]
  notifications   InAppNotification[]
  notificationPreference NotificationPreference?

  @@index([walletAddress])
}

/// Trade model representing a transaction on the Amana platform
/// - tradeId: Unique identifier for the trade (from blockchain)
/// - buyerAddress: Wallet address of the buyer (stored as lowercase)
/// - sellerAddress: Wallet address of the seller (stored as lowercase)
/// - amountUsdc: Amount in USDC (stored as string to preserve precision)
/// - status: Current status of the trade
model Trade {
  id            Int         @id @default(autoincrement())
  tradeId       String      @unique @db.VarChar(255)
  buyerAddress  String      @db.VarChar(255)
  sellerAddress String      @db.VarChar(255)
  amountUsdc    String      @default("0") @db.VarChar(100)
  buyerLossBps  Int         @default(5000)
  sellerLossBps Int         @default(5000)
  /// Monotonic optimistic concurrency counter for status transitions.
  version       Int         @default(0)
  status        TradeStatus @default(CREATED)
  /// Canonical timestamp set once when the trade transitions to FUNDED.
  fundedAt      DateTime?
  /// Canonical timestamp set once when the trade transitions to DELIVERED.
  deliveredAt   DateTime?
  /// Canonical timestamp set once when the trade transitions to COMPLETED.
  completedAt   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  buyer         User             @relation("buyer", fields: [buyerAddress], references: [walletAddress])
  seller        User             @relation("seller", fields: [sellerAddress], references: [walletAddress])
  dispute       Dispute?
  manifest      DeliveryManifest?
  evidence      TradeEvidence[]
  notes           TradeNote[]
  watchlistEntries UserWatchlist[]
  releaseMilestones EscrowReleaseMilestone[]

  @@index([tradeId])
  @@index([buyerAddress])
  @@index([sellerAddress])
  @@index([status])
}

/// TradeTemplate stores a user's reusable trade terms. The buyer is always the
/// authenticated user at creation time, so it is intentionally not persisted.
model TradeTemplate {
  id              Int      @id @default(autoincrement())
  userAddress     String   @db.VarChar(255)
  name            String   @db.VarChar(100)
  sellerAddress   String   @db.VarChar(255)
  amountUsdc      String   @db.VarChar(100)
  buyerLossBps    Int      @default(5000)
  sellerLossBps   Int      @default(5000)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userAddress], references: [walletAddress], onDelete: Cascade)

  @@unique([userAddress, name])
  @@index([userAddress, createdAt])
}

/// UserWatchlist is a user-scoped bookmark. The composite unique constraint
/// makes adding the same trade idempotent and prevents duplicate favorites.
model UserWatchlist {
  id          Int      @id @default(autoincrement())
  userAddress String   @db.VarChar(255)
  tradeId     String   @db.VarChar(255)
  createdAt   DateTime @default(now())

  user  User  @relation(fields: [userAddress], references: [walletAddress], onDelete: Cascade)
  trade Trade @relation(fields: [tradeId], references: [tradeId], onDelete: Cascade)

  @@unique([userAddress, tradeId])
  @@index([userAddress, createdAt])
  @@index([tradeId])
}

/// DisputeCategory model for classifying disputes
/// - name: Human-readable category name (unique)
/// - description: Optional description of the category
model DisputeCategory {
  id          Int       @id @default(autoincrement())
  name        String    @unique @db.VarChar(100)
  description String?   @db.Text
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  disputes    Dispute[]

  @@index([name])
  @@index([isActive])
}

/// Dispute model representing a dispute on a trade
/// - tradeId: Reference to the associated trade
/// - initiator: Wallet address of the user initiating the dispute (stored as lowercase)
/// - reason: Reason for the dispute
/// - status: Current status of the dispute
/// - resolvedAt: Timestamp when the dispute was resolved
/// - categoryId: Optional reference to a DisputeCategory
model Dispute {
  id           Int              @id @default(autoincrement())
  tradeId      String           @unique @db.VarChar(255)
  initiator    String           @db.VarChar(255)
  reason       String           @db.Text
  status       DisputeStatus    @default(OPEN)
  /// Monotonic optimistic concurrency counter for status transitions.
  version      Int              @default(0)
  resolvedAt   DateTime?
  categoryId   Int?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  // Relations
  trade        Trade            @relation(fields: [tradeId], references: [tradeId], onDelete: Cascade)
  initiatorUser User            @relation("initiator", fields: [initiator], references: [walletAddress])
  category     DisputeCategory? @relation(fields: [categoryId], references: [id])

  @@index([tradeId])
  @@index([initiator])
  @@index([status])
  @@index([categoryId])
}

/// DeliveryManifest — submitted by the seller before shipping.
/// Sensitive fields (driverName, driverIdNumber) are hashed with SHA-256 before
/// being sent on-chain; raw values are stored here for mediator review.
model DeliveryManifest {
  id                      Int      @id @default(autoincrement())
  tradeId                 String   @unique @db.VarChar(255)
  /// Raw (plaintext) driver name — mediator-only access
  driverName              String   @db.VarChar(255)
  /// Raw driver ID number
  driverIdNumber          String   @db.VarChar(255)
  vehicleRegistration     String   @db.VarChar(100)
  routeDescription        String   @db.Text
  expectedDeliveryAt      DateTime
  /// SHA-256 hash of driverName — stored on-chain
  driverNameHash          String   @db.VarChar(64)
  /// SHA-256 hash of driverIdNumber — stored on-chain
  driverIdHash            String   @db.VarChar(64)
  createdAt               DateTime @default(now())

  trade Trade @relation(fields: [tradeId], references: [tradeId], onDelete: Cascade)

  @@index([tradeId])
}

/// TradeEvidence — IPFS-pinned files submitted as delivery evidence
model TradeEvidence {
  id          Int      @id @default(autoincrement())
  tradeId     String   @db.VarChar(255)
  cid         String   @db.VarChar(255)
  filename    String   @db.VarChar(255)
  mimeType    String   @db.VarChar(100)
  uploadedBy  String   @db.VarChar(255)
  createdAt   DateTime @default(now())

  trade Trade @relation(fields: [tradeId], references: [tradeId], onDelete: Cascade)

  @@index([tradeId])
  @@index([cid])
}

/// ProcessedEvent model for exactly-once event processing deduplication
/// - ledgerSequence: The sequence number of the ledger containing the event
/// - contractId: The contract that emitted the event
/// - eventId: The unique on-chain event ID
/// - processedAt: Timestamp of when the event was processed
model ProcessedEvent {
  id              Int      @id @default(autoincrement())
  ledgerSequence  Int
  contractId      String   @db.VarChar(255)
  eventId         String   @db.VarChar(255)
  processedAt     DateTime @default(now())

  @@unique([ledgerSequence, contractId, eventId])
  @@index([ledgerSequence])
}

/// ChainEventOutbox model for durable event processing state and retries
model ChainEventOutbox {
  id              Int                  @id @default(autoincrement())
  ledgerSequence  Int
  contractId      String               @db.VarChar(255)
  eventId         String               @db.VarChar(255)
  eventType       String               @db.VarChar(100)
  tradeId         String               @db.VarChar(255)
  payload         Json
  status          ChainEventSyncStatus @default(PENDING)
  attempts        Int                  @default(0)
  nextAttemptAt   DateTime             @default(now())
  lastError       String?              @db.Text
  deadLetteredAt  DateTime?
  processedAt     DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@unique([ledgerSequence, contractId, eventId])
  @@index([status, nextAttemptAt])
  @@index([ledgerSequence])
}

/// Vault model representing a savings vault on Soroban
/// - vaultId: Unique identifier from blockchain
/// - ownerAddress: Wallet address of vault owner (lowercase)
/// - balanceUsdc: Current balance in USDC (string for precision)
/// - createdAt: Timestamp of vault creation
model Vault {
  id              Int      @id @default(autoincrement())
  vaultId         String   @unique @db.VarChar(255)
  ownerAddress    String   @db.VarChar(255)
  balanceUsdc     String   @default("0") @db.VarChar(100)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  owner           User     @relation(fields: [ownerAddress], references: [walletAddress])
  goals           Goal[]

  @@index([vaultId])
  @@index([ownerAddress])
}

/// Goal model representing a savings goal linked to a vault
/// - goalId: Unique identifier from blockchain
/// - vaultId: Reference to parent vault
/// - targetAmountUsdc: Target amount to save (string for precision)
/// - currentAmountUsdc: Current accumulated amount (string for precision)
/// - deadline: Target completion date
/// - status: Goal status (ACTIVE, COMPLETED, CANCELLED)
/// - createdAt: Timestamp of goal creation
model Goal {
  id                  Int         @id @default(autoincrement())
  goalId              String      @unique @db.VarChar(255)
  vaultId             String      @db.VarChar(255)
  userId              Int
  targetAmountUsdc    String      @db.VarChar(100)
  currentAmountUsdc   String      @default("0") @db.VarChar(100)
  deadline            DateTime
  status              GoalStatus  @default(ACTIVE)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  // Relations
  vault               Vault       @relation(fields: [vaultId], references: [vaultId], onDelete: Cascade)
  user                User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([goalId])
  @@index([vaultId])
  @@index([userId])
  @@index([status])
}

/// RefreshToken model for tracking active sessions and preventing reuse
model RefreshToken {
  id        Int      @id @default(autoincrement())
  tokenHash String   @unique @db.VarChar(255)
  jti       String   @unique @db.VarChar(255)
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([jti])
}

model UserWallet {
  id            Int      @id @default(autoincrement())
  userId        Int
  walletAddress String   @db.VarChar(255)
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, walletAddress])
  @@index([userId])
  @@index([walletAddress])
}

/// Webhook model representing a registered webhook endpoint owned by a user
/// - url: The target URL to which webhook payloads are delivered
/// - description: Optional human-readable label
/// - isActive: Whether the webhook is currently accepting deliveries
model Webhook {
  id          Int      @id @default(autoincrement())
  userAddress String   @db.VarChar(255)
  url         String   @db.VarChar(2048)
  description String?  @db.VarChar(255)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user             User                    @relation(fields: [userAddress], references: [walletAddress], onDelete: Cascade)
  deliveryAttempts WebhookDeliveryAttempt[]

  @@index([userAddress, createdAt])
}

/// WebhookDeliveryAttempt records a single delivery attempt for a webhook
/// - timestamp: When the delivery was attempted
/// - status: Outcome of the delivery (e.g. "success", "failure")
/// - statusCode: HTTP status code returned by the target
/// - responseBody: Response body from the target (if any)
model WebhookDeliveryAttempt {
  id           Int      @id @default(autoincrement())
  webhookId    Int
  timestamp    DateTime @default(now())
  status       String   @db.VarChar(50)
  statusCode   Int
  responseBody String?  @db.Text

  // Relations
  webhook      Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId, timestamp])
}

/// WebhookSubscription stores event subscription endpoints owned by a user.
model WebhookSubscription {
  id          Int      @id @default(autoincrement())
  url         String   @db.VarChar(500)
  events      String[]
  secretHash  String   @db.VarChar(64)
  isActive    Boolean  @default(true)
  userId      Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
}

/// InAppNotification represents an in-app notification for a user
/// - type: Category of notification (e.g. "trade_update", "dispute", "system")
/// - isRead: Whether the notification has been read
/// - metadata: Optional JSON payload with additional context
model InAppNotification {
  id          Int      @id @default(autoincrement())
  userAddress String   @db.VarChar(255)
  title       String   @db.VarChar(255)
  message     String   @db.Text
  type        String   @db.VarChar(50)
  isRead      Boolean  @default(false)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user        User     @relation(fields: [userAddress], references: [walletAddress], onDelete: Cascade)

  @@index([userAddress, isRead, createdAt])
}

/// NotificationPreference stores a user's trade notification channel choices.
/// The JSON payload is keyed by event type, with values like ["email", "push"].
model NotificationPreference {
  id          Int      @id @default(autoincrement())
  userAddress String   @unique @db.VarChar(255)
  preferences Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userAddress], references: [walletAddress], onDelete: Cascade)

  @@index([userAddress])
}

/// TradeNote — private encrypted notes attached to a trade by a buyer or seller.
/// Each note is encrypted at rest with AES-256-GCM. Only the author can decrypt
/// their own notes. Notes are limited to 2000 characters of plaintext.
model TradeNote {
  id          Int      @id @default(autoincrement())
  tradeId     String   @db.VarChar(255)
  authorAddress String @db.VarChar(255)
  /// AES-256-GCM encrypted note content (base64-encoded iv + ciphertext + tag)
  content     String   @db.Text
  createdAt   DateTime @default(now())

  trade Trade @relation(fields: [tradeId], references: [tradeId], onDelete: Cascade)

  @@index([tradeId, authorAddress, createdAt])
  @@index([tradeId, createdAt])
  @@index([authorAddress])
}

/// EscrowReleaseMilestone represents one pre-defined partial release point.
/// releasedAt is set after the matching on-chain release event is confirmed.
model EscrowReleaseMilestone {
  id             Int       @id @default(autoincrement())
  tradeId        String    @db.VarChar(255)
  milestoneIndex Int
  amountUsdc     String    @db.VarChar(100)
  dueAt          DateTime
  conditionHash  String?   @db.VarChar(255)
  releasedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  trade          Trade     @relation(fields: [tradeId], references: [tradeId], onDelete: Cascade)

  @@unique([tradeId, milestoneIndex])
  @@index([tradeId, dueAt])
  @@index([tradeId, releasedAt])
}
